---
import BlogPost from '../../layouts/BlogPost.astro';
import { getAllPostDetails, getRelatedPosts, type BlogPostDetail } from '../../lib/blog-data';

export async function getStaticPaths() {
	const details = await getAllPostDetails();
	return details.map((detail) => ({
		params: { slug: detail.slug },
		props: { detail },
	}));
}

interface Props {
	detail: BlogPostDetail;
}

const { detail } = Astro.props;

let contentHtml: string | null = null;
let Content: any = null;
let title: string;
let description: string;
let pubDate: Date;
let updatedDate: Date | null;
let heroImage: string | null;
let category: string | null;

if (detail.source === 'microcms') {
	contentHtml = detail.contentHtml;
	title = detail.title;
	description = detail.description;
	pubDate = detail.pubDate;
	updatedDate = detail.updatedDate;
	heroImage = detail.heroImage;
	category = detail.category;
} else {
	const { entry } = detail;
	const rendered = await entry.render();
	Content = rendered.Content;
	title = entry.data.title;
	description = entry.data.description;
	pubDate = entry.data.pubDate;
	updatedDate = entry.data.updatedDate ?? null;
	heroImage = entry.data.heroImage ?? null;
	category = entry.data.category ?? null;
}

const relatedPosts = await getRelatedPosts(detail.slug, category, 4);
---

<BlogPost
	title={title}
	description={description}
	pubDate={pubDate}
	updatedDate={updatedDate}
	heroImage={heroImage}
	contentHtml={contentHtml}
	slug={detail.slug}
	category={category}
	relatedPosts={relatedPosts}
>
	{Content && <Content />}
</BlogPost>
