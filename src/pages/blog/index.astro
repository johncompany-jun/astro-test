---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getAllPostSummaries, getPostSummariesByCategory } from '../../lib/blog-data';
import FormattedDate from '../../components/FormattedDate.astro';
import { CATEGORIES, buildBreadcrumbJsonLd } from '../../lib/seo';

const posts = (await getAllPostSummaries()).sort(
	(a, b) => b.pubDate.valueOf() - a.pubDate.valueOf()
);

const categories = CATEGORIES.map((c) => ({
	id: c.id,
	title: c.label,
	description: c.description,
}));

const postsByCategory = await getPostSummariesByCategory();

const breadcrumbItems = [
	{ name: 'HOME', href: '/' },
	{ name: 'BLOG' },
];

const jsonLd = [
	buildBreadcrumbJsonLd(
		breadcrumbItems.map((b) => ({
			name: b.name,
			url: b.href ?? '/blog/',
		}))
	),
];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${SITE_TITLE} | Blog`} description={SITE_DESCRIPTION} jsonLd={jsonLd} />
	</head>
	<body>
		<Header />
		<main class="space-y-16">
			<div class="pt-6">
				<Breadcrumbs items={breadcrumbItems} />
			</div>
			<section class="space-y-4 text-center">
				<p class="font-display text-sm uppercase tracking-[0.4em] text-brand-text/60">Blog</p>
				<h1 class="font-display text-4xl font-semibold tracking-[0.12em] text-brand-text md:text-5xl">
					最新記事
				</h1>
				<p class="mx-auto max-w-2xl text-sm leading-7 tracking-[0.1em] text-brand-text/70">
					テレワーク、プログラミング、キャリアアップに関する記事をカテゴリー別にまとめています。
				</p>
				<form action="/blog/search/" method="get" class="mx-auto mt-6 flex max-w-md gap-2">
					<input
						type="search"
						name="q"
						placeholder="記事を検索..."
						class="flex-1 rounded-xl border border-brand-text/20 bg-white px-4 py-2.5 text-sm tracking-[0.08em] text-brand-text shadow-lg-soft outline-none transition placeholder:text-brand-text/40 focus:border-brand-text/40"
					/>
					<button
						type="submit"
						class="rounded-xl border border-brand-text/30 px-4 py-2.5 text-xs uppercase tracking-[0.2em] text-brand-text transition hover:bg-brand-text hover:text-white"
					>
						検索
					</button>
				</form>
			</section>

			<section class="space-y-6" aria-label="最新3件">
				<h2 class="font-display text-xl uppercase tracking-[0.3em] text-brand-text/70">Latest</h2>
				<ul class="grid gap-6 md:grid-cols-3">
					{posts.slice(0, 3).map((post) => (
						<li class="group rounded-2xl border border-brand-text/10 p-5 shadow-lg-soft transition hover:-translate-y-1 hover:shadow-xl-soft">
							<p class="text-xs uppercase tracking-[0.2em] text-brand-text/50">
								<FormattedDate date={post.pubDate} />
							</p>
							<a href={`/blog/${post.slug}/`} class="mt-3 block text-lg font-semibold tracking-[0.08em] text-brand-text transition group-hover:text-brand-text/70">
								{post.title}
							</a>
							<p class="mt-3 text-sm leading-7 tracking-[0.08em] text-brand-text/70">{post.description}</p>
						</li>
					))}
				</ul>
			</section>

			{categories.map((category) => {
				const allCategoryPosts = postsByCategory[category.id] ?? [];
				const categoryPosts = allCategoryPosts.slice(0, 5);
				return (
					<section id={category.id} class="space-y-6">
						<div class="flex flex-wrap items-end justify-between gap-3">
							<div class="space-y-2">
								<p class="font-display text-sm uppercase tracking-[0.4em] text-brand-text/60">{category.title}</p>
								<h2 class="text-2xl font-semibold tracking-[0.12em] text-brand-text">
									{category.description}
								</h2>
							</div>
							<a
								href={`/blog/${category.id}/`}
								class="text-xs uppercase tracking-[0.2em] text-brand-text/70 underline-offset-4 transition hover:text-brand-text hover:underline"
							>
								もっと見る ({allCategoryPosts.length})
							</a>
						</div>
						<ul class="space-y-4">
							{categoryPosts.map((post) => (
								<li class="rounded-2xl border border-brand-text/10 p-5 shadow-lg-soft transition hover:-translate-y-0.5 hover:shadow-xl-soft">
									<div class="flex flex-wrap items-center justify-between gap-3">
										<p class="text-xs uppercase tracking-[0.2em] text-brand-text/50">
											<FormattedDate date={post.pubDate} />
										</p>
										<span class="text-xs uppercase tracking-[0.3em] text-brand-text/50">{category.title}</span>
									</div>
									<a href={`/blog/${post.slug}/`} class="mt-2 block text-lg font-semibold tracking-[0.08em] text-brand-text transition hover:text-brand-text/70">
										{post.title}
									</a>
									<p class="mt-2 text-sm leading-7 tracking-[0.08em] text-brand-text/70">{post.description}</p>
								</li>
							))}
							{categoryPosts.length === 0 && (
								<li class="rounded-2xl border border-dashed border-brand-text/20 p-6 text-sm tracking-[0.08em] text-brand-text/50">
									準備中の記事カテゴリーです。
								</li>
							)}
						</ul>
					</section>
				);
			})}
		</main>
		<Footer />
	</body>
</html>
